generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id           String        @id @default(uuid())
  name         String
  logoUrl      String?       @map("logo_url")
  primaryColor String        @default("#3B82F6") @map("primary_color")
  createdAt    DateTime      @default(now()) @map("created_at")
  publicEvents PublicEvent[]
  users        User[]

  @@map("Organization")
}

model User {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  email          String       @unique
  passwordHash   String       @map("password_hash")
  role           UserRole
  firstName      String       @map("first_name")
  lastName       String       @map("last_name")
  createdAt      DateTime     @default(now()) @map("created_at")
  timezone       String       @default("UTC")
  counselor      Counselor?   @relation("UserToCounselor")
  student        Student?     @relation("UserToStudent")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("User")
}

model Counselor {
  userId              String                  @id @map("user_id")
  isAdmin             Boolean                 @default(false) @map("is_admin")
  user                User                    @relation("UserToCounselor", fields: [userId], references: [id], onDelete: Cascade)
  availabilities      CounselorAvailability[]
  settings            CounselorSettings?
  eventAssignments    EventAssignment[]
  completedSignups    EventSignup[]
  meetings            Meeting[]               @relation("CounselorMeetings")
  meetingNotes        MeetingNote[]
  hostMeetingRequests MeetingRequest[]        @relation("HostMeetingRequests")
  comments            ProfileComment[]
  overrides           ProfileOverride[]
  caseload            Student[]               @relation("CounselorCaseload")

  @@map("Counselor")
}

model Student {
  userId               String               @id @map("user_id")
  graduationYear       Int                  @map("graduation_year")
  currentGrade         GradeLevel           @map("current_grade")
  profileCompletionPct Int                  @default(0) @map("profile_completion_pct")
  counselorId          String?              @map("counselor_id")
  phase                StudentPhase         @default(Onboarding)
  notificationsEnabled Boolean              @default(true) @map("notifications_enabled")
  academicProfile      AcademicProfile?
  achievements         Achievement[]
  activities           Activity[]
  changeLogs           ChangeLog[]
  applications         CollegeApplication[]
  meetings             Meeting[]            @relation("StudentMeetings")
  meetingNotes         MeetingNote[]
  meetingRequests      MeetingRequest[]     @relation("StudentMeetingRequests")
  personalProfile      PersonalProfile?
  goals                ProfileGoal[]
  profileOverride      ProfileOverride?
  projectExperiences   ProjectExperience[]
  counselor            Counselor?           @relation("CounselorCaseload", fields: [counselorId], references: [userId])
  user                 User                 @relation("UserToStudent", fields: [userId], references: [id], onDelete: Cascade)
  targetColleges       TargetCollege[]
  testScores           TestScore[]
  transcripts          Transcript[]

  @@map("Student")
}

model PersonalProfile {
  studentId      String    @id @map("student_id")
  dateOfBirth    DateTime? @map("date_of_birth")
  phone          String?
  currentSchool  String?   @map("current_school")
  schoolLocation String?   @map("school_location")
  createdAt      DateTime  @default(now()) @map("created_at")
  parentEmail    String    @default("") @map("parent_email")
  parentName     String    @default("") @map("parent_name")
  parentPhone    String    @default("") @map("parent_phone")
  preferredName  String?   @map("preferred_name")
  student        Student   @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  @@map("PersonalProfile")
}

model AcademicProfile {
  studentId         String            @id @map("student_id")
  curriculumType    CurriculumType    @map("curriculum_type")
  gradingSystemType GradingSystemType @map("grading_system_type")
  currentGpa        String?           @map("current_gpa")
  createdAt         DateTime          @default(now()) @map("created_at")
  student           Student           @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  @@map("AcademicProfile")
}

model Subject {
  id             String         @id @default(cuid())
  curriculumType CurriculumType @map("curriculum_type")
  subjectName    String         @map("subject_name")

  @@unique([subjectName, curriculumType])
  @@map("Subject")
}

model Transcript {
  id          String      @id @default(cuid())
  studentId   String      @map("student_id")
  courseName  String      @map("course_name")
  gradeLevel  GradeLevel  @map("grade_level")
  semester    Semester
  gradeValue  String      @map("grade_value")
  honorsLevel HonorsLevel @default(Standard) @map("honors_level")
  isBoardExam Boolean     @default(false) @map("is_board_exam")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  student     Student     @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  @@unique([studentId, courseName, gradeLevel, semester])
  @@map("Transcript")
}

model Activity {
  id           String           @id @default(cuid())
  studentId    String           @map("student_id")
  activityName String           @map("activity_name")
  role         String?
  hoursPerWeek Int              @map("hours_per_week")
  weeksPerYear Int              @map("weeks_per_year")
  description  String?
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  gradeLevel   GradeLevel       @map("grade_level")
  category     ActivityCategory
  student      Student          @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  @@map("Activity")
}

model ProjectExperience {
  id             String         @id @default(cuid())
  studentId      String         @map("student_id")
  experienceType ExperienceType @map("experience_type")
  title          String
  organization   String?
  startDate      DateTime       @map("start_date")
  endDate        DateTime?      @map("end_date")
  isOngoing      Boolean        @default(false) @map("is_ongoing")
  roleTitle      String?        @map("role_title")
  description    String?
  createdAt      DateTime       @default(now()) @map("created_at")
  student        Student        @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  @@map("ProjectExperience")
}

model Achievement {
  id               String            @id @default(cuid())
  studentId        String            @map("student_id")
  achievementType  AchievementType   @map("achievement_type")
  title            String
  organization     String?
  gradeLevel       GradeLevel?       @map("grade_level")
  dateAchieved     DateTime?         @map("date_achieved")
  description      String?
  recognitionLevel RecognitionLevel? @map("recognition_level")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  metrics          String?
  verifiableLink   String?           @map("verifiable_link")
  student          Student           @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  @@map("Achievement")
}

model College {
  id             String               @id @default(cuid())
  name           String               @unique
  country        String               @default("United States")
  acceptanceRate Float?               @map("acceptance_rate")
  avgGpa         Float?               @map("avg_gpa")
  avgSat         Int?                 @map("avg_sat")
  avgAct         Int?                 @map("avg_act")
  rankingUsNews  Int?                 @map("ranking_us_news")
  isActive       Boolean              @default(true) @map("is_active")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  applications   CollegeApplication[]
  targetColleges TargetCollege[]

  @@map("College")
}

model CollegeApplication {
  id                    String            @id @default(cuid())
  studentId             String            @map("student_id")
  collegeId             String            @map("college_id")
  targetCategory        TargetCategory    @map("target_category")
  applicationStatus     ApplicationStatus @map("application_status")
  applicationDeadline   DateTime?         @map("application_deadline")
  decisionDeadline      DateTime?         @map("decision_deadline")
  essayStatus           String            @default("Not Started") @map("essay_status")
  supplementsStatus     String            @default("Not Started") @map("supplements_status")
  recommendationStatus  String            @default("Not Requested") @map("recommendation_status")
  testScoresSent        Boolean           @default(false) @map("test_scores_sent")
  applicationPortalLink String?           @map("application_portal_link")
  notes                 String?
  decisionReceivedDate  DateTime?         @map("decision_received_date")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  college               College           @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  student               Student           @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  @@unique([studentId, collegeId])
  @@map("CollegeApplication")
}

model TestScore {
  id                  String   @id @default(cuid())
  studentId           String   @map("student_id")
  testType            String   @map("test_type")
  testDate            DateTime @map("test_date")
  compositeScore      Int      @map("composite_score")
  createdAt           DateTime @default(now()) @map("created_at")
  englishScore        Int?     @map("english_score")
  mathScore           Int?     @map("math_score")
  readingWritingScore Int?     @map("reading_writing_score")
  scienceScore        Int?     @map("science_score")
  student             Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  @@map("TestScore")
}

model TargetCollege {
  id             String         @id @default(cuid())
  studentId      String         @map("student_id")
  collegeId      String         @map("college_id")
  priority       Int?
  targetCategory TargetCategory @map("target_category")
  college        College        @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  student        Student        @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  @@unique([studentId, collegeId])
  @@map("TargetCollege")
}

model Meeting {
  id                    String                 @id @default(uuid())
  studentId             String                 @map("student_id")
  hostId                String                 @map("host_id")
  meetingType           MeetingType            @map("meeting_type")
  startTime             DateTime               @map("start_time")
  endTime               DateTime               @map("end_time")
  timezone              String                 @default("UTC")
  status                ScheduledMeetingStatus @default(Upcoming)
  conferencePlatform    PreferredConference?   @map("conference_platform")
  conferenceId          String?                @map("conference_id")
  conferenceJoinUrl     String?                @map("conference_join_url")
  conferenceHostUrl     String?                @map("conference_host_url")
  googleCalendarEventId String?                @map("google_calendar_event_id")
  agenda                String?
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  host                  Counselor              @relation("CounselorMeetings", fields: [hostId], references: [userId], onDelete: Cascade)
  student               Student                @relation("StudentMeetings", fields: [studentId], references: [userId], onDelete: Cascade)
  note                  MeetingNote?
  meetingRequest        MeetingRequest?

  @@map("Meeting")
}

model MeetingNote {
  id              String    @id @default(cuid())
  meetingId       String    @unique @map("meeting_id")
  studentId       String    @map("student_id")
  counselorId     String    @map("counselor_id")
  actionItems     String[]  @map("action_items")
  nextMeetingDate DateTime? @map("next_meeting_date")
  studentMood     String?   @map("student_mood")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  counselorNotes  String?   @map("counselor_notes")
  recordingUrl    String?   @map("recording_url")
  studentNotes    String?   @map("student_notes")
  summaryAi       String?   @map("summary_ai")
  transcriptUrl   String?   @map("transcript_url")
  counselor       Counselor @relation(fields: [counselorId], references: [userId], onDelete: Cascade)
  meeting         Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  student         Student   @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  @@map("MeetingNote")
}

model ChangeLog {
  id          String       @id @default(cuid())
  studentId   String       @map("student_id")
  changeType  ChangeType   @map("change_type")
  entityType  String       @map("entity_type")
  entityId    String?      @map("entity_id")
  action      ChangeAction
  fieldName   String?      @map("field_name")
  oldValue    String?      @map("old_value")
  newValue    String?      @map("new_value")
  description String
  createdAt   DateTime     @default(now()) @map("created_at")
  student     Student      @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  @@map("ChangeLog")
}

model ProfileGoal {
  id           String     @id @default(cuid())
  studentId    String     @map("student_id")
  goalType     GoalType   @map("goal_type")
  category     String
  targetValue  String     @map("target_value")
  currentValue String     @map("current_value")
  deadline     DateTime?
  status       GoalStatus @default(Not_Started)
  priority     Int?
  notes        String?
  createdAt    DateTime   @default(now()) @map("created_at")
  completedAt  DateTime?  @map("completed_at")
  student      Student    @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  @@map("ProfileGoal")
}

model ProfileOverride {
  id             String    @id @default(cuid())
  studentId      String    @unique @map("student_id")
  overrideScore  Int       @map("override_score")
  overrideReason String    @map("override_reason")
  overriddenBy   String    @map("overridden_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  counselor      Counselor @relation(fields: [overriddenBy], references: [userId])
  student        Student   @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  @@map("ProfileOverride")
}

model ProfileComment {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  content   String
  userId    String    @map("user_id")
  counselor Counselor @relation(fields: [userId], references: [userId])

  @@map("ProfileComment")
}

model MeetingRequest {
  id                    String               @id @default(uuid())
  studentId             String               @map("student_id")
  hostId                String               @map("host_id")
  requestedStart        DateTime             @map("requested_start")
  requestedEnd          DateTime             @map("requested_end")
  meetingType           MeetingType          @map("meeting_type")
  studentNote           String?              @map("student_note")
  status                MeetingRequestStatus @default(Pending)
  hostNote              String?              @map("host_note")
  suggestedStart        DateTime?            @map("suggested_start")
  suggestedEnd          DateTime?            @map("suggested_end")
  scheduledMeetingId    String?              @unique @map("scheduled_meeting_id")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")
  googleCalendarEventId String?              @map("google_calendar_event_id")
  host                  Counselor            @relation("HostMeetingRequests", fields: [hostId], references: [userId], onDelete: Cascade)
  meeting               Meeting?             @relation(fields: [scheduledMeetingId], references: [id])
  student               Student              @relation("StudentMeetingRequests", fields: [studentId], references: [userId], onDelete: Cascade)

  @@map("MeetingRequest")
}

model CounselorSettings {
  userId                 String              @id @map("user_id")
  preferredConference    PreferredConference @default(Zoom) @map("preferred_conference")
  googleAccessToken      String?             @map("google_access_token")
  googleRefreshToken     String?             @map("google_refresh_token")
  googleTokenExpiry      DateTime?           @map("google_token_expiry")
  googleCalendarId       String?             @map("google_calendar_id")
  googleConnected        Boolean             @default(false) @map("google_connected")
  zoomAccessToken        String?             @map("zoom_access_token")
  zoomRefreshToken       String?             @map("zoom_refresh_token")
  zoomTokenExpiry        DateTime?           @map("zoom_token_expiry")
  zoomUserId             String?             @map("zoom_user_id")
  zoomConnected          Boolean             @default(false) @map("zoom_connected")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")
  bufferTime             Int                 @default(15) @map("buffer_time")
  defaultMeetingDuration Int                 @default(30) @map("default_meeting_duration")
  counselor              Counselor           @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("CounselorSettings")
}

model CounselorAvailability {
  id          String    @id @default(uuid())
  counselorId String    @map("counselor_id")
  dayOfWeek   Int       @map("day_of_week")
  startTime   String    @map("start_time")
  endTime     String    @map("end_time")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  counselor   Counselor @relation(fields: [counselorId], references: [userId], onDelete: Cascade)

  @@unique([counselorId, dayOfWeek])
  @@map("CounselorAvailability")
}

model PublicEvent {
  id             String            @id @default(uuid())
  organizationId String            @map("organization_id")
  title          String
  description    String?
  location       String
  startDate      DateTime          @map("start_date")
  endDate        DateTime          @map("end_date")
  headerText     String?           @default("YOUR GLOBAL FUTURE STARTS HERE") @map("header_text")
  subheaderText  String?           @default("Schedule your FREE 30-minute consultation") @map("subheader_text")
  slotDuration   Int               @default(30) @map("slot_duration")
  successMessage String?           @map("success_message")
  footerContent  Json?             @map("footer_content")
  isActive       Boolean           @default(true) @map("is_active")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  assignments    EventAssignment[]
  slots          EventSlot[]
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("PublicEvent")
}

model EventAssignment {
  id          String      @id @default(uuid())
  eventId     String      @map("event_id")
  counselorId String      @map("counselor_id")
  counselor   Counselor   @relation(fields: [counselorId], references: [userId], onDelete: Cascade)
  event       PublicEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, counselorId])
  @@map("EventAssignment")
}

model EventSlot {
  id          String        @id @default(uuid())
  eventId     String        @map("event_id")
  startTime   DateTime      @map("start_time")
  duration    Int           @default(30)
  capacity    Int           @default(1)
  bookedCount Int           @default(0) @map("booked_count")
  isActive    Boolean       @default(true) @map("is_active")
  signups     EventSignup[]
  event       PublicEvent   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, startTime])
  @@map("EventSlot")
}

model EventSignup {
  id                   String        @id @default(uuid())
  slotId               String        @map("slot_id")
  duration             Int
  prospectName         String        @map("prospect_name")
  prospectEmail        String?       @map("prospect_email")
  prospectPhone        String        @map("prospect_phone")
  studentGrade         String?       @map("student_grade")
  status               BookingStatus @default(Confirmed)
  completedAt          DateTime?     @map("completed_at")
  completedBy          String?       @map("completed_by")
  counselorNotes       String?       @map("counselor_notes")
  didAttend            Boolean?      @map("did_attend")
  createdAt            DateTime      @default(now()) @map("created_at")
  completedByCounselor Counselor?    @relation(fields: [completedBy], references: [userId])
  slot                 EventSlot     @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@index([slotId])
  @@map("EventSignup")
}

enum UserRole {
  counselor
  student
}

enum StudentPhase {
  Onboarding
  Profile_Building
  College_Applications
}

enum GradeLevel {
  ninth
  tenth
  eleventh
  twelfth
}

enum CurriculumType {
  CBSE
  ICSE
  IB
  CAIE
  State_Board
  US_High_School
  Other
}

enum GradingSystemType {
  Marks_Out_Of_100
  Percentage
  IB_Scale
  Letter_Grade
  Other
}

enum HonorsLevel {
  Standard
  Honors
  AP
  IB_HL
  IB_SL
}

enum Semester {
  Fall
  Spring
  Full_Year
}

enum AchievementType {
  Award_Honor
  Competition
  Leadership
  Social_Impact
  Extracurricular
}

enum RecognitionLevel {
  School
  Inter_School
  District
  City
  State
  National
  International
}

enum ExperienceType {
  Academic_Project
  Independent_Project
  Research
  Internship
  Summer_Program
  Work_Experience
  Volunteer_Project
}

enum ApplicationStatus {
  Not_Started
  Planning
  Researching
  Preparing
  In_Progress
  Submitted
  Accepted
  Rejected
  Waitlisted
  Deferred
  Withdrawn
}

enum GoalType {
  Academic
  Testing
  Activity
  Achievement
  Project
  Other
}

enum ChangeAction {
  Created
  Updated
  Deleted
  Completed
}

enum ChangeType {
  Profile_Update
  Goal_Progress
  New_Addition
  Improvement
  Milestone
}

enum MeetingType {
  Initial
  Regular
  Check_In
  Goal_Review
  Application_Review
  Crisis
  Final
}

enum GoalStatus {
  Not_Started
  In_Progress
  Completed
  Deferred
  Cancelled
}

enum TargetCategory {
  Reach
  Match
  Safety
}

enum ActivityCategory {
  Academic
  Arts_Music
  Athletics
  Community_Service
  Cultural
  Leadership
  Other
}

enum MeetingRequestStatus {
  Pending
  Accepted
  Declined
  ChangeSuggested
  Cancelled
}

enum ScheduledMeetingStatus {
  Upcoming
  InProgress
  Completed
  Cancelled
  NoShow
}

enum PreferredConference {
  Zoom
  GoogleMeet
}

enum BookingStatus {
  Confirmed
  Cancelled
  NoShow
  Completed
}
